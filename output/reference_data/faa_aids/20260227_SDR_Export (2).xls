ace:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'>LANDING GEAR</td><td style='white-space:nowrap;text-align:left;'>E</td><td style='white-space:nowrap;text-align:left;'>70006108</td><td style='white-space:nowrap;text-align:left;'>FAULTED</td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'>684</td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'>144</td><td style='white-space:nowrap;text-align:left;'>I</td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space: