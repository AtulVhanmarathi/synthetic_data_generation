ace:nowrap;text-align:left;'>PILATS</td><td style='white-space:nowrap;text-align:left;'>PITOT SYSTEM</td><td style='white-space:nowrap;text-align:left;'>9651112305</td><td style='white-space:nowrap;text-align:left;'>304077</td><td style='white-space:nowrap;text-align:left;'>SHORTED</td><td style='white-space:nowrap;text-align:left;'>ZONE 100</td><td style='white-space:nowrap;text-align:left;'>4736</td><td style='white-space:nowrap;text-align:left;'>3490</td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><td style='white-space:nowrap;text-align:left;'></td><